  "vectors": [
    {
      "id": "htlc-hp-01",
      "title": "Lock funds — happy path",
      "description": "Lock tCeBM linked to an accepted FX agreement. Returns 201 with status LOCKED.",
      "category": "happy-path",
      "preconditions": {
        "authenticatedAs": "CB-CostaRica (0xCB001_CostaRica)",
