      },
      "expectedOutput": {
        "status": 200,
        "body": {
          "contractId": "{{SAME_AS_INPUT}}",
          "status": "REFUNDED"
        }
      },
      "notes": "Refund returns UTXOs to the original sender's address."
    },
    {
      "id": "htlc-err-03",
      "title": "Refund HTLC — not yet expired (409)",
      "description": "Attempting refund before timeLock expiry returns 409.",
      "category": "error",
      "preconditions": {
        "htlcExists": true,
        "htlcStatus": "LOCKED",
        "timeLockNotExpired": true
      },
      "input": {
        "method": "POST",
        "path": "/api/v1/htlc/refund",
        "body": {
          "contractId": "{{VALID_CONTRACT_ID}}"
        }
      },
      "expectedOutput": {
        "status": 409
      },
      "notes": "Refund is only valid after timeLock expiry. This prevents the sender from reclaiming funds while the receiver still has time to settle."
    },
    {
      "id": "htlc-err-04",
      "title": "Refund HTLC — already settled (409)",
      "description": "Attempting to refund an HTLC that was already settled returns 409.",
      "category": "error",
      "preconditions": {
        "htlcExists": true,
        "htlcStatus": "SETTLED"
      },
      "input": {
        "method": "POST",
        "path": "/api/v1/htlc/refund",
        "body": {
          "contractId": "{{VALID_CONTRACT_ID}}"
        }
      },
      "expectedOutput": {
        "status": 409
      },
      "notes": "Once settled, funds belong to the receiver. Refund is impossible."
