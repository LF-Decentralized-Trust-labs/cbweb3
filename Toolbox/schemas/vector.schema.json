{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toolbox.cbweb3.org/schemas/vector.schema.json",
  "title": "CBWeb3 Toolbox Test Vector File",
  "description": "Schema for test vector JSON files (deterministic input/output fixtures)",
  "type": "object",
  "required": ["contract", "contractVersion", "vectors"],
  "properties": {
    "contract": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the interface contract these vectors validate"
    },
    "contractVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the contract"
    },
    "generatedAt": {
      "type": "string",
      "description": "Date the vectors were generated"
    },
    "hashFunction": {
      "type": "string",
      "description": "Hash function used for cryptographic test data (e.g., SHA-256)"
    },
    "syntheticSecrets": {
      "type": "object",
      "description": "Synthetic secret values used in test vectors (for independent verification)"
    },
    "vectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/vector"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "vector": {
      "type": "object",
      "required": ["id", "title", "description", "category", "preconditions", "input", "expectedOutput"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z]+-[a-z]+-\\d+$",
          "description": "Unique vector identifier (format: <domain>-<category>-<number>)"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": ["happy-path", "error", "edge-case"]
        },
        "preconditions": {
          "type": "object",
          "description": "State that MUST exist before the test runs"
        },
        "input": {
          "type": "object",
          "required": ["method", "path"],
          "properties": {
            "method": {
              "type": "string",
              "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
            },
            "path": {
              "type": "string",
              "pattern": "^/api/v\\d+/"
            },
            "body": {
              "type": "object"
            }
          }
        },
        "expectedOutput": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "integer",
              "minimum": 100,
              "maximum": 599
            },
            "body": {
              "type": "object"
            }
          }
        },
        "notes": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    }
  }
}
